{
  "expo": {
    "name": "MECANIX Workshop",
    "slug": "mecanix-workshop",
    "version": "0.0.1",
    "scheme": "mecanix-workshop",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#0087FF"
    },
    "ios": {
      "bundleIdentifier": "com.mecanix.workshop",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "MECANIX needs camera access for vehicle inspections and photos"
      }
    },
    "android": {
      "package": "com.mecanix.workshop",
      "adaptiveIcon": {
        "backgroundColor": "#0087FF"
      },
      "permissions": ["CAMERA"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "cameraPermission": "MECANIX needs camera access for vehicle inspections"
        }
      ]
    ],
    "extra": {
      "router": { "origin": false },
      "eas": { "projectId": "mecanix-workshop" }
    },
    "experiments": {
      "tsconfigPaths": true
    }
  }
}
