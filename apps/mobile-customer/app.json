{
  "expo": {
    "name": "MECANIX Customer",
    "slug": "mecanix-customer",
    "version": "0.0.1",
    "scheme": "mecanix-customer",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#0087FF"
    },
    "ios": {
      "bundleIdentifier": "com.mecanix.customer",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "MECANIX needs camera access to capture vehicle photos"
      }
    },
    "android": {
      "package": "com.mecanix.customer",
      "adaptiveIcon": {
        "backgroundColor": "#0087FF"
      },
      "permissions": [
        "CAMERA",
        "NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0087FF"
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "8d044997-34e1-4243-b300-b1bc5a906d17"
      }
    },
    "owner": "rajakurban"
  }
}
