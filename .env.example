# ──────────────────────────────────────────────────
# MECANIX Platform — Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────

# ── Backend API ──
PORT=4000
NODE_ENV=production

# ── Supabase ──
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Security ──
# Comma-separated list of allowed CORS origins (default: localhost:3000,3001)
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000,http://localhost:3001
# Secret for signing public estimate tokens (min 32 chars, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ESTIMATE_TOKEN_SECRET=
# AES-256 key for encrypting sensitive data at rest (64 hex chars, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# ── WhatsApp Business API (Meta) ──
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=mecanix_verify_2026

# ── Redis (BullMQ queues) ──
REDIS_URL=redis://localhost:6379

# ── Mobile Apps (set in Expo/EAS) ──
# EXPO_PUBLIC_API_URL=https://your-api.railway.app/api/v1
# EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# EXPO_PUBLIC_PROJECT_ID=your-expo-project-id
